# -----------------------------------------------------------------------------
# Modèle de configuration de PRODUCTION.
#
# Sur le serveur : copiez ce fichier en `.env.local` (dans le même dossier `api/`,
# au-dessus du docroot `api/public`) et renseignez les valeurs ci-dessous.
#
# `.env.local` n'est JAMAIS versionné (gitignoré) ni uploadé/écrasé par les
# déploiements (exclu du FTPS). Ce modèle `.env.local.example`, lui, est
# versionné et déployé — il ne doit donc contenir AUCUN secret réel.
# -----------------------------------------------------------------------------

APP_ENV=prod

# Généré avec : openssl rand -hex 32
APP_SECRET=

# Mot de passe URL-encodé si caractères spéciaux. serverVersion = version réelle
# MariaDB (SELECT VERSION();). Exemple :
# DATABASE_URL="mysql://UTILISATEUR:MOTDEPASSE@127.0.0.1:3306/BASE?serverVersion=mariadb-10.11.10&charset=utf8mb4"
DATABASE_URL=

# Origine autorisée pour le CORS (front). En prod :
CORS_ALLOW_ORIGIN='^https://commanderbuilder\.fr$'

# Cookie JWT sécurisé (HTTPS obligatoire) : true en prod
JWT_COOKIE_SECURE=true

# Clé secrète hCaptcha (dashboard hcaptcha.com). Clé de test (laisse passer tout
# le monde, protection inopérante) : 0x0000000000000000000000000000000000000000
HCAPTCHA_SECRET=
